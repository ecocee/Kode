// -----------------------------------------------
// TEST 1: CPU Loop  -  sum 0 to 1,000,000
// -----------------------------------------------
print("[1] CPU Loop  (sum 0..1,000,000)")

let sum = 0
let i = 0
while (i < 1000000) {
    sum = sum + i
    i = i + 1
}

print("    Result:")
print(sum)
print("")

