// Advanced Module System Examples

import "config" as cfg;
import { add, multiply, PI } from "math";
import { Person, Address, createPerson } from "data";

fn main() {
    print(cfg.APP_NAME);
    print(cfg.VERSION);
    let result = add(10, 5);
    print(result);
}

// Logger exports
export fn log(message: string) {
    print("[LOG] ");
    print(message);
}

export fn debug(message: string) {
    print("[DEBUG] ");
    print(message);
}

export fn error(message: string) {
    print("[ERROR] ");
    print(message);
}

// Data types
export struct User {
    id: int,
    name: string,
    email: string
}

export struct Post {
    id: int,
    userId: int,
    title: string,
    content: string
}

// Configuration
export const APP_NAME = "MyAwesomeApp";
export const VERSION = "2.5.1";
export const MAX_USERS = 1000;
export const MAX_REQUESTS = 60;

export let PORT = 8080;
export let HOST = "localhost";

export fn getAppInfo() {
    print(APP_NAME);
    print(VERSION);
}

// Utility functions
export fn formatMessage(prefix: string, message: string) {
    print(prefix);
    print(": ");
    print(message);
}

export fn concatenate(a: string, b: string) {
    print(a);
    print(b);
}

export fn formatNumber(n: int) {
    print(n);
}

// Module with interdependencies
import { User, Post } from "models";

export fn getUserInfo(userId: int) {
    print("Getting user ");
    print(userId);
}

export fn getPostsByUser(userId: int) {
    print("Getting posts for user ");
    print(userId);
}
