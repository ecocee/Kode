// Comprehensive test of all new Kode bytecode features

print("========== KODE BYTECODE FEATURE TEST ==========")

// 1. TEST: While Loops
print("")
print("1. WHILE LOOPS:")
let counter = 0
while (counter < 3) {
    print(counter)
    counter = counter + 1
}

// 2. TEST: Bitwise Operators
print("")
print("2. BITWISE OPERATORS:")
let a = 12
let b = 5
print("a & b =")
print(a & b)
print("a | b =")
print(a | b)
print("a ^ b =")
print(a ^ b)
print("a << 1 =")
print(a << 1)
print("a >> 1 =")
print(a >> 1)

// 3. TEST: For Loop with Break/Continue (basic version)
print("")
print("3. FOR LOOPS WITH ASSIGNMENT:")
for (let i = 0; i < 5; i = i + 1) {
    print(i)
}

// 4. TEST: If-Else-If chains
print("")
print("4. IF-ELSE-IF CHAINS:")
let x = 15
if (x < 10) {
    print("Less than 10")
} else {
    if (x < 20) {
        print("Between 10 and 20")
    } else {
        print("Greater than or equal to 20")
    }
}

// 5. TEST: All Arithmetic Operators
print("")
print("5. ARITHMETIC OPERATORS:")
let num1 = 20
let num2 = 3
print("Add:")
print(num1 + num2)
print("Subtract:")
print(num1 - num2)
print("Multiply:")
print(num1 * num2)
print("Divide:")
print(num1 / num2)
print("Modulo:")
print(num1 % num2)

// 6. TEST: Logical Operators
print("")
print("6. LOGICAL OPERATORS:")
print("true && true =")
print(true && true)
print("true && false =")
print(true && false)
print("true || false =")
print(true || false)
print("!true =")
print(!true)

// 7. TEST: Comparison Operators
print("")
print("7. COMPARISON OPERATORS:")
let p = 50
let q = 50
print("p == q =")
print(p == q)
print("p != q =")
print(p != q)
print("p < q =")
print(p < q)
print("p > q =")
print(p > q)
print("p <= q =")
print(p <= q)
print("p >= q =")
print(p >= q)

// 8. TEST: Functions with Multiple Arguments
print("")
print("8. FUNCTIONS:")
func add(x: int, y: int) = x + y
func multiply(a: int, b: int) = a * b
func power(base: int, exp: int) = base * exp

print("add(10, 5) =")
print(add(10, 5))
print("multiply(6, 7) =")
print(multiply(6, 7))

// 9. TEST: Nested Function Calls
print("")
print("9. NESTED FUNCTION CALLS:")
func square(n: int) = n * n
func double(n: int) = n * 2

print("square(double(3)) =")
print(square(double(3)))
print("double(square(4)) =")
print(double(square(4)))

// 10. TEST: Complex Expressions
print("")
print("10. COMPLEX EXPRESSIONS:")
let result = (10 + 5) * 2 - 3
print("(10 + 5) * 2 - 3 =")
print(result)

print("")
print("========== ALL TESTS COMPLETED SUCCESSFULLY ==========")
