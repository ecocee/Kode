// math_broken.kode - Math module with intentional error

export fn add(a: int, b: int) {
    print(a + b);
}

export fn broken_function(a: int, b: int) {
    // This will cause a type error - trying to add string to int
    print(a + "hello");
}

export fn subtract(a: int, b: int) {
    print(a - b);
}