{
    "scopeName": "source.kode",
    "name": "Kode",
    "fileTypes": ["kode"],
    "patterns": [
      {
        "match": "\\b(let|fn|return|if|else|for|while|break|continue|match|struct|enum|impl|trait|use|mod|pub|const|async|await|spawn|select|channel|import|service|defer|go|main|in|catch)\\b",
        "name": "keyword.control.kode"
      },
      {
        "match": "\\b(int|string|bool|float)\\b",
        "name": "storage.type.kode"
      },
      {
        "match": "\\b(true|false)\\b",
        "name": "constant.language.kode"
      },
      {
        "match": "\\b(null)\\b",
        "name": "constant.language.kode"
      },
      {
        "match": "\"(\\\\.|[^\"])*\"",
        "name": "string.quoted.double.kode"
      },
      {
        "match": "\\b[0-9]+\\b",
        "name": "constant.numeric.integer.kode"
      },
      {
        "match": "\\b[0-9]+\\.[0-9]+\\b",
        "name": "constant.numeric.float.kode"
      },
      {
        "match": "\\+|-|\\*|/|%|==|!=|<=|>=|<|>|=|&&|\\|\\||&|\\||\\^|<<|>>|->",
        "name": "keyword.operator.kode"
      },
      {
        "match": "//.*$",
        "name": "comment.line.double-slash.kode"
      },
      {
        "match": "/\\*",
        "name": "comment.block.kode",
        "begin": "/\\*",
        "end": "\\*/"
      },
      {
        "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b",
        "name": "identifier.kode"
      }
    ],
    "uuid": "12345678-90ab-cdef-1234-567890abcdef"
  }
  
