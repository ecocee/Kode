// config.kode - Configuration constants
// Exports: App configuration values

export const APP_NAME = "KodeApp"
export const VERSION = "1.0.0"
export const DEBUG_MODE = false
export const MAX_CONNECTIONS = 100
export const TIMEOUT_MS = 5000

export let RETRY_ATTEMPTS = 3
export let LOG_LEVEL = "INFO"

export fn getAppInfo() -> string {
    APP_NAME
}

export fn isDebugEnabled() -> bool {
    DEBUG_MODE
}
