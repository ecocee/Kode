// Functions example in Kode
func add(a: int, b: int): int {
  a + b
}

func greet(name: str) {
  print("Hello, " + name)
}

func factorial(n: int): int {
  if n <= 1 {
    1
  } else {
    n * factorial(n - 1)
  }
}

func main() {
  let result = add(5, 3)
  print(result)

  greet("Kode")

  let fact = factorial(5)
  print(fact)
}
